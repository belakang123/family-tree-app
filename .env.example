# ============================================================
# KONFIGURASI FIREBASE (dipakai di FRONTEND - src/config/firebase.js)
# Didapat dari: Firebase Console > Project Settings > General > Your apps
# Salin file ini menjadi ".env" lalu isi nilainya. Wajib diawali "VITE_"
# agar terbaca oleh Vite di sisi client.
# ============================================================
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ============================================================
# KONFIGURASI GOOGLE DRIVE (dipakai di BACKEND - api/upload.js)
# JANGAN diisi di .env lokal untuk deploy — isi langsung di dashboard
# Vercel (Project Settings > Environment Variables) karena bersifat rahasia.
# Untuk development lokal via `vercel dev`, boleh diisi di sini.
# ============================================================
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=